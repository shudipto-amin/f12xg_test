# Default: ignore everything, only script files are tracked.
# (json/csv test fixtures will be force-added individually later)
*

# Allow traversal into directories so git can find script files within them
!*/

# Jupyter / Python temporaries - excluded even inside otherwise-allowed dirs
.ipynb_checkpoints/
.virtual_documents/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
.ipynb_checkpoints
*-checkpoint.ipynb
*-checkpoint.py

# Track script files
!*.sh
!*.bash
!*.py
!*.ipynb
!*.md

# Track these files
!.gitignore
!.gitattributes
